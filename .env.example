# === Novabot Docker Configuration ===

# VERPLICHT: IP-adres van de machine waarop de container draait
# Dit IP wordt gebruikt voor DNS rewrite (*.lfibot.com -> dit IP)
TARGET_IP=192.168.0.100

# Optioneel: JWT secret voor dashboard authenticatie
# JWT_SECRET=willekeurig_lang_geheim

# Optioneel: upstream DNS server voor niet-lfibot.com domeinen
# UPSTREAM_DNS=8.8.8.8

# Optioneel: extra domeinen die ook naar TARGET_IP moeten wijzen (komma-gescheiden)
# Alleen nodig als je firmware hebt geflasht met custom domeinen
# EXTRA_DOMAINS=ramonvanbruggen.nl

# === Home Assistant MQTT Bridge (optioneel) ===
# Uncomment om maaier/charger data door te sturen naar Home Assistant
# HA_MQTT_HOST=192.168.0.248
# HA_MQTT_PORT=1883
# HA_MQTT_USER=mqtt
# HA_MQTT_PASS=mqtt
