{
  "productName": "OpenNova",
  "version": "1.0.0",
  "identifier": "com.opennovabot.setup",
  "build": {
    "frontendDist": "../wizard/dist",
    "devUrl": "http://localhost:7789",
    "beforeDevCommand": "",
    "beforeBuildCommand": "npm run build:wizard"
  },
  "app": {
    "windows": [
      {
        "title": "OpenNova Setup",
        "width": 900,
        "height": 700,
        "minWidth": 600,
        "minHeight": 500,
        "url": "http://localhost:7789"
      }
    ],
    "security": {
      "csp": "default-src 'self' http://localhost:* ws://localhost:*; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; connect-src 'self' http://localhost:* ws://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/novabot-server"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
