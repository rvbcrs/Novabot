{
  "name": "opennovabot-bootstrap",
  "version": "1.0.0",
  "description": "Standalone OTA installer wizard for OpenNova self-hosted mower firmware",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build:wizard": "cd wizard && npm run build",
    "generate-bundle": "node scripts/generate-wizard-bundle.mjs",
    "build:server": "npm run generate-bundle && tsc",
    "build": "npm run build:wizard && npm run build:server",
    "package": "npm run build && npx @yao-pkg/pkg dist/index.js --target node20-macos-arm64,node20-macos-x64,node20-windows-x64 --output dist/novabot-bootstrap"
  },
  "dependencies": {
    "@stoprocent/noble": "^2.3.17",
    "aedes": "^0.47.0",
    "express": "^4.18.3",
    "mqtt": "^4.3.8",
    "multer": "^1.4.5-lts.1",
    "multicast-dns": "^7.2.5",
    "socket.io": "^4.8.3",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20",
    "@types/ssh2": "^1.15.5",
    "@yao-pkg/pkg": "^5.11.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  },
  "pkg": {
    "targets": [
      "node20-macos-arm64",
      "node20-macos-x64",
      "node20-windows-x64"
    ],
    "outputPath": "dist"
  }
}
