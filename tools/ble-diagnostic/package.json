{
  "name": "novabot-ble-diagnostic",
  "version": "1.0.0",
  "description": "BLE diagnostic tool for Novabot mower and charger radio inspection",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "npm run build:wizard && tsx src/index.ts",
    "build:wizard": "cd wizard && npm run build",
    "generate-bundle": "node scripts/generate-wizard-bundle.mjs",
    "build:server": "npm run generate-bundle && tsc",
    "build": "npm run build:wizard && npm run build:server"
  },
  "dependencies": {
    "@stoprocent/noble": "^1.15.0",
    "express": "^4.18.3",
    "mqtt": "^5.10.0",
    "socket.io": "^4.7.5",
    "ssh2": "^1.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20",
    "@types/ssh2": "^1.15.5",
    "tsx": "^4.7.2",
    "typescript": "^5.4.3"
  }
}
